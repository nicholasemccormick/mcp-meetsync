# MeetSync API base URL (no trailing slash)
MEETSYNC_API_URL=http://localhost:3000

# API key sent in X-API-Key header — must match API_KEY_SECRET in the MeetSync API
MEETSYNC_API_KEY=change-me

# Transport mode: 'stdio' (default, for MCP clients) or 'http' (for Smithery/Railway)
TRANSPORT=http

# HTTP port when TRANSPORT=http
PORT=3000
