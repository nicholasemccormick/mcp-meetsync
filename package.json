{
  "name": "mcp-meetsync",
  "version": "1.0.0",
  "description": "MCP server for MeetSync — calendar negotiation API for AI agents. Exposes all 19 MeetSync endpoints as MCP tools so any LLM can autonomously schedule meetings.",
  "main": "dist/index.js",
  "bin": {
    "mcp-meetsync": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "ai-agent",
    "scheduling",
    "calendar",
    "cosmic-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
